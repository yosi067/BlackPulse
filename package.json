{
  "name": "omnicenter-ai",
  "version": "1.0.0",
  "private": true,
  "description": "OmniCenter AI - Blackwell Series Server Remote Monitoring Platform",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:sim\" \"npm run dev:dash\"",
    "dev:sim": "npm -w packages/simulator run dev",
    "dev:dash": "npm -w packages/dashboard run dev",
    "build": "npm -w packages/dashboard run build",
    "build:wasm": "npm -w packages/wasm-processor run build",
    "docker:up": "docker-compose up --scale bmc-simulator=5 -d",
    "docker:down": "docker-compose down"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
